# Runtime mode
USE_LOCAL_SQLITE=1

# Database Configuration
# Required only when USE_LOCAL_SQLITE=0
DATABASE_URL=postgresql://postgres:password@db.project-id.supabase.co:5432/postgres

# Supabase Configuration
SUPABASE_URL=https://project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Audio Storage Bucket
STORAGE_BUCKET_NAME=audio-records

# Azure Speech Configuration
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus

# OpenAI Support Chat
OPENAI_API_KEY=your_openai_api_key
OPENAI_SUPPORT_MODEL=gpt-4o-mini

# Gemini Support Chat and Voice Transcription
GEMINI_API_KEY=your_gemini_api_key
GEMINI_SUPPORT_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIBE_MODEL=gemini-3-flash-preview

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256

# Application Settings
DEBUG=False
ENVIRONMENT=production
