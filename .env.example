# ============================================
# Speech-Enabled BPO Platform — Environment Template
# Copy this to `.env` and fill in your own values.
# NEVER commit the real `.env` to git.
# ============================================

# --- Database ---
USE_LOCAL_SQLITE=0
DATABASE_URL=postgresql://postgres.<project>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# --- Supabase Backend/Admin ---
SUPABASE_URL=https://ghgixstcnzserhiidjkn.supabase.co
SUPABASE_PUBLISHABLE_KEY=<publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_SERVICE_KEY=<service-role-key>

# --- Supabase Frontend/Public ---
# Safe to expose in the browser bundle. Never place the service-role key in frontend env files.
NEXT_PUBLIC_SUPABASE_URL=https://ghgixstcnzserhiidjkn.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-key>
VITE_SUPABASE_URL=https://ghgixstcnzserhiidjkn.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
STORAGE_BUCKET_NAME=attachments
PROFILE_STORAGE_BUCKET_NAME=profile-pictures
CALL_SIMULATION_STORAGE_BUCKET_NAME=call-recordings
CALL_SIMULATION_ASSET_BUCKET_NAME=call-ringers
MICROLEARNING_STORAGE_BUCKET_NAME=microlearning-videos

# --- App Secrets ---
SECRET_KEY=<generate-a-64-char-random-string>

# --- URLs ---
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000

# --- Azure Speech (optional) ---
AZURE_SPEECH_KEY=<your-azure-speech-key>
AZURE_SPEECH_REGION=eastus

# --- AI Keys (optional) ---
GEMINI_API_KEY=<your-gemini-key>
OPENAI_API_KEY=<your-openai-key>
