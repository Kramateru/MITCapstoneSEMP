# Supabase Configuration (Required)
# Public keys only. Never place SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SERVICE_KEY in this file.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-key>
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>

# Backend Configuration (Required)
# Use your Render backend URL (e.g., https://your-backend.onrender.com)
NEXT_PUBLIC_BACKEND_URL=your-backend-url
# Optional: WebSocket override (e.g., wss://your-backend.onrender.com)
NEXT_PUBLIC_BACKEND_WS_URL=your-websocket-url
